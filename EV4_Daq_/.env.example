# Copy this file to ".env" and fill in your real values.
# The .env file is git-ignored so your token never gets committed.

# --- InfluxDB Cloud v3 ---
INFLUX_HOST=https://us-east-1-1.aws.cloud2.influxdata.com
INFLUX_TOKEN=paste-your-influxdb-token-here
INFLUX_ORG=EV 4
# In InfluxDB v3 a "bucket" is called a database. Use the name you created.
INFLUX_DATABASE=ev4_can_data

# --- CAN interface ---
# On the Raspberry Pi keep these defaults.
CAN_CHANNEL=can0
CAN_INTERFACE=socketcan

# --- Paths ---
DBC_DIR=DBC
LOG_DIR=can_logs

# Optional: a label written as a tag on every point so you can
# filter a specific test/run in InfluxDB. Leave blank to disable.
SESSION_TAG=
